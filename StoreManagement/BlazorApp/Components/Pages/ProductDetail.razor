@page "/product/{id:int}"
@using BlazorApp.Models
@rendermode InteractiveServer

<PageTitle>@(Product?.ProductName ?? "Chi tiết sản phẩm") - GreenStore</PageTitle>

<section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-fresh-50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-warm-200/30 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10 lg:pt-12 lg:pb-16">
        <!-- Breadcrumb -->
        <nav class="flex items-center text-sm text-gray-500 mb-6 space-x-1">
            <a href="/" class="hover:text-primary-600 font-semibold">Trang chủ</a>
            <span>/</span>
            <span class="hover:text-primary-600 cursor-pointer" @onclick="GoBack">Sản phẩm</span>
            <span>/</span>
            <span class="text-gray-700 font-semibold line-clamp-1 max-w-xs sm:max-w-md">
                @(Product?.ProductName ?? "Đang tải...")
            </span>
        </nav>

        @if (IsLoading)
        {
            <!-- Loading skeleton -->
            <div class="grid lg:grid-cols-2 gap-10 items-start animate-pulse">
                <div class="bg-gray-200 rounded-3xl aspect-square shadow-lg"></div>
                <div class="space-y-4">
                    <div class="h-7 bg-gray-200 rounded w-2/3"></div>
                    <div class="h-5 bg-gray-200 rounded w-1/3"></div>
                    <div class="h-6 bg-gray-200 rounded w-1/2"></div>
                    <div class="h-24 bg-gray-200 rounded"></div>
                    <div class="h-10 bg-gray-200 rounded w-1/3"></div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="bg-red-50 border border-red-200 rounded-2xl p-6 flex items-start gap-4">
                <span class="text-2xl">⚠️</span>
                <div>
                    <h2 class="text-lg font-bold text-red-800 mb-1">Không thể tải sản phẩm</h2>
                    <p class="text-sm text-red-600">@ErrorMessage</p>
                    <button class="mt-4 inline-flex items-center px-4 py-2 rounded-xl bg-primary-500 text-white text-sm font-semibold shadow-md hover:bg-primary-600 transition"
                            @onclick="ReloadAsync">
                        Thử lại
                    </button>
                </div>
            </div>
        }
        else if (Product == null)
        {
            <div class="text-center py-16">
                <div class="text-6xl mb-4">🔍</div>
                <h2 class="text-2xl font-extrabold text-gray-800 mb-2">Không tìm thấy sản phẩm</h2>
                <p class="text-gray-500 mb-6">Có thể sản phẩm đã bị xoá hoặc không còn tồn tại.</p>
                <a href="/"
                   class="inline-flex items-center px-6 py-3 rounded-2xl bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold shadow-lg hover:from-primary-600 hover:to-primary-700 transition">
                    Quay lại trang chủ
                </a>
            </div>
        }
        else
        {
            <div class="grid lg:grid-cols-2 gap-10 items-start">
                <div class="relative">
                    <div class="relative overflow-hidden rounded-3xl shadow-2xl bg-gray-50 aspect-square">
                        <img src="@Product.ImageUrl"
                             alt="@Product.ProductName"
                             class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" />

                        @if ((Product.StockQuantity ?? 0) <= 10 && (Product.StockQuantity ?? 0) > 0)
                        {
                            <div class="absolute top-4 left-4 px-3 py-1.5 rounded-full bg-warm-500 text-white text-xs font-bold shadow-lg">
                                Còn @Product.StockQuantity @Product.Unit
                            </div>
                        }

                        @if ((Product.StockQuantity ?? 0) <= 0)
                        {
                            <div class="absolute top-4 left-4 px-3 py-1.5 rounded-full bg-gray-900/80 text-white text-xs font-bold shadow-lg">
                                Hết hàng
                            </div>
                        }
                    </div>
                </div>

                <div class="space-y-6">
                    
                    <h1 class="text-3xl lg:text-4xl font-extrabold text-gray-900 leading-snug">
                        @Product.ProductName
                    </h1>

                    
                    <!-- Category and Unit -->
                    <div class="mt-4 space-y-2 text-sm">
                        <!-- Rating + Sold -->
                        <div class="flex items-center gap-3">
                            <div class="flex items-center gap-1 text-orange-500 font-semibold">
                                <span>4.7 </span>
                                <i class="fa fa-star text-yellow-500"></i>
                            </div>

                            <span class="text-gray-400">|</span>

                            <div class="text-gray-600">
                                <span class="font-semibold text-gray-800">233</span> lượt đánh giá
                            </div>

                            <span class="text-gray-400">|</span>

                            <div class="text-gray-600">
                                <span class="font-semibold text-gray-800">255</span> đã bán
                            </div>

                        </div>

                        <!-- Category + Unit -->
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded">
                                @(!string.IsNullOrWhiteSpace(Product.CategoryName) 
                                ? Product.CategoryName 
                                : "Đang cập nhật")
                            </span>

                            <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded">
                                Đơn vị: <b>@Product.Unit</b>
                            </span>
                        </div>

                    </div>

                    <!-- Delivery Information -->
                    <div class="mt-4 p-3 bg-gray-50 rounded-lg border text-sm">

                        <div class="flex items-center gap-2 text-gray-700">
                            <i class="fa fa-truck text-green-600"></i>
                            <span class="font-medium">Vận chuyển</span>
                        </div>

                        <div class="mt-1 ml-6 text-gray-600">
                            Dự kiến giao hàng:
                            <span class="font-semibold text-gray-900">
                                2 – 4 ngày
                            </span>
                            <span class="text-gray-400">(kể từ khi đặt)</span>
                        </div>

                        <div class="mt-1 ml-6 text-green-600 flex items-center gap-1">
                            <i class="fa fa-check-circle"></i>
                            <span>Giao nhanh</span>
                        </div>

                    </div>

                    <div class="flex items-center flex-wrap gap-4">
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Giá hiện tại</p>
                            <p class="text-3xl font-extrabold text-primary-600">
                                @FormatPrice(Product.Price)
                            </p>
                        </div>
                        <div class="h-10 w-px bg-gray-200"></div>
                        <div>
                            <p class="text-sm text-gray-500 mb-1">Tình trạng</p>
                            @if ((Product.StockQuantity ?? 0) > 0)
                            {
                                <p class="text-sm font-semibold text-green-600">
                                    Còn hàng
                                </p>
                            }
                            else
                            {
                                <p class="text-sm font-semibold text-red-500">
                                    Hết hàng
                                </p>
                            }
                        </div>
                    </div>

                    <div class="flex flex-wrap items-center gap-4 pt-2">
                        <button class="inline-flex items-center justify-center px-6 py-3 rounded-2xl bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold shadow-xl shadow-primary-500/30 hover:from-primary-600 hover:to-primary-700 transition disabled:opacity-60 disabled:cursor-not-allowed"
                                @onclick="AddToCartAsync"
                                disabled="@(Product.StockQuantity <= 0)">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                            Thêm vào giỏ
                        </button>
                    </div>

                    <div class="bg-primary-50 border border-primary-100 rounded-2xl p-4 space-y-2">
                        <p class="text-xs font-semibold text-primary-700 uppercase tracking-wide">Mẹo bảo quản</p>
                        <p class="text-sm text-primary-800">
                            Bảo quản nơi khô ráo, thoáng mát hoặc trong ngăn mát tủ lạnh. Nên sử dụng trong vòng
                            2–3 ngày kể từ khi nhận hàng để đảm bảo độ tươi ngon.
                        </p>
                    </div>
                </div>
            </div>

            <div class="grid gap-5 lg:gap-6 lg:grid-cols-3 mt-5">
                <div class="lg:col-span-2 bg-white rounded-2xl p-5 shadow-md space-y-3">
                    <h2 class="text-sm font-bold text-gray-800 uppercase tracking-wide">Mô tả sản phẩm</h2>
                    <p class="text-sm text-gray-600 leading-relaxed">
                        @Product.ProductName được GreenStore tuyển chọn kỹ càng từ các nhà cung cấp uy tín, đảm bảo
                        nguồn gốc rõ ràng và quy trình bảo quản đạt chuẩn. Phù hợp cho bữa ăn gia đình mỗi ngày,
                        mang lại sự an tâm về chất lượng và độ tươi ngon.
                    </p>
                    <ul class="mt-3 space-y-1 text-sm text-gray-600 list-disc list-inside">
                        <li>Đóng gói cẩn thận, giao nhanh trong ngày.</li>
                        <li>Giá tốt, ưu đãi thường xuyên cho khách hàng thân thiết.</li>
                        <li>Bảo quản đúng chuẩn để giữ trọn hương vị và dinh dưỡng.</li>
                    </ul>
                </div>

                <div class="space-y-3">
                    <div class="bg-white rounded-2xl p-4 shadow-md space-y-2">
                        <h3 class="text-sm font-bold text-gray-800 uppercase tracking-wide">Dịch vụ GreenStore</h3>
                        <div class="flex items-start gap-3 text-sm text-gray-600">
                            <span class="text-lg">🚚</span>
                            <p>Giao hàng trong vòng <span class="font-semibold text-gray-800">2 giờ</span> tại khu vực nội thành.</p>
                        </div>
                        <div class="flex items-start gap-3 text-sm text-gray-600">
                            <span class="text-lg">✅</span>
                            <p>Đổi trả trong <span class="font-semibold text-gray-800">24 giờ</span> nếu sản phẩm không đạt chất lượng.</p>
                        </div>
                        <div class="flex items-start gap-3 text-sm text-gray-600">
                            <span class="text-lg">💬</span>
                            <p>Hỗ trợ tư vấn 8:00 - 22:00 mỗi ngày.</p>
                        </div>
                        <div class="flex items-start gap-3 text-sm text-gray-600">
                            <span class="text-lg">🛡️</span>
                            <p>Kiểm tra hàng trước khi thanh toán.</p>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</section>


