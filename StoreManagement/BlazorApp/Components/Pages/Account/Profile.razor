@page "/profile"
@using BlazorApp.Models.Auth
@using BlazorApp.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Profile> Logger
@rendermode InteractiveServer

<PageTitle>Thông tin cá nhân - FreshMart</PageTitle>

@if (!_isLoaded)
{
    <!-- Loading Screen -->
    <div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-fresh-50 flex items-center justify-center">
        <div class="text-center">
            <div class="inline-flex items-center justify-center">
                <div class="w-12 h-12 rounded-full border-4 border-primary-200 border-t-primary-600 animate-spin"></div>
            </div>
            <p class="text-gray-600 mt-4 font-semibold">Đang tải thông tin...</p>
        </div>
    </div>
}
else
{
    <div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-fresh-50 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-8 animate-fade-in">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 shadow-lg shadow-primary-500/30 mb-4">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>
                <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Thông tin cá nhân</h1>
                <p class="text-gray-600">Quản lý thông tin tài khoản của bạn</p>
            </div>

            @if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
            {
                <!-- Profile Card -->
                <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden animate-slide-up">
                    <!-- Header Gradient -->
                    <div class="h-32 bg-gradient-to-r from-primary-500 to-fresh-500 relative">
                        <div class="absolute -bottom-12 left-8">
                            <div class="w-24 h-24 rounded-full bg-white flex items-center justify-center shadow-lg border-4 border-white">
                                <span class="text-4xl">👤</span>
                            </div>
                        </div>
                    </div>

                    <!-- Profile Info -->
                    <div class="pt-16 px-8 pb-8">
                        <div class="mb-6">
                            <h2 class="text-2xl font-bold text-gray-900">@AuthService.CurrentUser.Name</h2>
                            <p class="text-gray-500">Thành viên từ @AuthService.CurrentUser.CreatedAt.ToString("dd/MM/yyyy")</p>
                        </div>

                        <!-- Info Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Email -->
                            <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100">
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500 font-semibold">Email</p>
                                        <p class="text-sm font-bold text-gray-900">@(AuthService.CurrentUser.Email ?? "Chưa cập nhật")</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Phone -->
                            <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100">
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="w-10 h-10 rounded-full bg-fresh-100 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-fresh-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500 font-semibold">Số điện thoại</p>
                                        <p class="text-sm font-bold text-gray-900">@(AuthService.CurrentUser.Phone ?? "Chưa cập nhật")</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Address -->
                            <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 md:col-span-2">
                                <div class="flex items-start gap-3 mb-2">
                                    <div class="w-10 h-10 rounded-full bg-warm-100 flex items-center justify-center flex-shrink-0">
                                        <svg class="w-5 h-5 text-warm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500 font-semibold">Địa chỉ</p>
                                        <p class="text-sm font-bold text-gray-900">@(AuthService.CurrentUser.Address ?? "Chưa cập nhật")</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Customer ID -->
                            @* <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100">
                                <div class="flex items-center gap-3 mb-2">
                                    <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500 font-semibold">Mã khách hàng</p>
                                        <p class="text-sm font-bold text-gray-900">#@AuthService.CurrentUser.CustomerId.ToString("D6")</p>
                                    </div>
                                </div>
                            </div> *@
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-8 flex flex-col sm:flex-row gap-4">
                            <button @onclick="HandleLogout"
                                class="flex-1 py-4 px-6 rounded-xl bg-gradient-to-r from-red-500 to-red-600 text-white font-bold hover:from-red-600 hover:to-red-700 transition-all shadow-lg shadow-red-500/30 flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                <span>Đăng xuất</span>
                            </button>

                            <button @onclick="BackToHome"
                                class="flex-1 py-4 px-6 rounded-xl bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold hover:from-primary-600 hover:to-primary-700 transition-all shadow-lg shadow-primary-500/30 flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                <span>Về trang chủ</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Not Logged In -->
                <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-12 text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gray-100 mb-6">
                        <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900 mb-2">Bạn chưa đăng nhập</h2>
                    <p class="text-gray-600 mb-6">Vui lòng đăng nhập để xem thông tin cá nhân</p>
                    <a href="/login" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold rounded-xl hover:from-primary-600 hover:to-primary-700 transition-all shadow-lg shadow-primary-500/30">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                        </svg>
                        <span>Đăng nhập ngay</span>
                    </a>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _isLoaded = false;


    [Inject]
    private IToastService ToastService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Profile page initializing...");

        try
        {
            // Initialize auth state from localStorage
            await AuthService.InitializeAsync();

            Logger.LogInformation("Profile - IsAuthenticated: {IsAuth}, CurrentUser: {User}", 
                AuthService.IsAuthenticated, 
                AuthService.CurrentUser?.Name ?? "null");

            // Set loaded flag to show content
            _isLoaded = true;

            // Redirect to login if not authenticated - but allow UI to render first
            if (!AuthService.IsAuthenticated)
            {
                Logger.LogWarning("User not authenticated, redirecting to login");
                // Small delay to ensure UI renders
                await Task.Delay(100);
                Navigation.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing profile");
            _isLoaded = true;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        ToastService.ShowSuccess("Bạn đã đăng xuất. Hẹn gặp lại!", "Thành công!");
        Navigation.NavigateTo("/", replace: true);
    }

    private void BackToHome()
    {
        Navigation.NavigateTo("/", replace: true);
    }
}
