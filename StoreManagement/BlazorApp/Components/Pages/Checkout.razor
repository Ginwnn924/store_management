@page "/checkout"
@rendermode InteractiveServer
@using BlazorApp.Services
@using BlazorApp.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IAuthService AuthService
@inject ICartService CartService
@inject IPromotionService PromotionService
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject IOrderService OrderService

<PageTitle>Thanh toán - GreenStore</PageTitle>

@if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
{
    <div class="max-w-2xl mx-auto py-16 px-4 text-center">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
            <div class="w-12 h-12 border-4 border-primary-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
            <p class="text-gray-500">Đang kiểm tra đăng nhập...</p>
        </div>
    </div>
}
else
{
    <section class="bg-gray-50 min-h-screen py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Breadcrumb -->
            <nav class="flex items-center gap-2 text-sm mb-6">
                <a href="/" class="text-gray-500 hover:text-primary-600">Trang chủ</a>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                <a href="/cart" class="text-gray-500 hover:text-primary-600">Giỏ hàng</a>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                <span class="text-primary-600 font-medium">Thanh toán</span>
            </nav>

            <!-- Page Title -->
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-xl bg-primary-500 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                </div>
                <h1 class="text-2xl font-extrabold text-gray-800">Thanh toán</h1>
            </div>

            <div class="grid lg:grid-cols-3 gap-6">
                <!-- Left Column - Customer Info & Payment -->
                <div class="lg:col-span-2 space-y-5">
                    <!-- Thông tin khách hàng -->
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                        <div class="flex items-center gap-2 mb-5">
                            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            <h2 class="text-lg font-bold text-gray-800">Thông tin khách hàng</h2>
                        </div>
                        
                        <!-- Toggle Options -->
                        <div class="flex gap-3 mb-5">
                            <button type="button" 
                                    class="flex-1 py-3.5 px-4 rounded-xl border-2 text-sm font-bold transition-all flex items-center justify-center gap-2 @(useLoggedInUser ? "border-primary-500 bg-primary-500 text-white shadow-lg shadow-primary-500/30" : "border-gray-300 bg-white text-gray-700 hover:border-primary-300 hover:bg-primary-50")"
                                    @onclick="() => SetCustomerMode(true)">
                                @if (useLoggedInUser)
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                }
                                Dùng thông tin tài khoản
                            </button>
                            <button type="button" 
                                    class="flex-1 py-3.5 px-4 rounded-xl border-2 text-sm font-bold transition-all flex items-center justify-center gap-2 @(!useLoggedInUser ? "border-primary-500 bg-primary-500 text-white shadow-lg shadow-primary-500/30" : "border-gray-300 bg-white text-gray-700 hover:border-primary-300 hover:bg-primary-50")"
                                    @onclick="() => SetCustomerMode(false)">
                                @if (!useLoggedInUser)
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                }
                                Nhập thông tin mới
                            </button>
                        </div>
                        
                        @if (useLoggedInUser)
                        {
                            <!-- Display logged in user info -->
                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Họ và tên *</label>
                                    <div class="px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-800">
                                        @AuthService.CurrentUser.Name
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Số điện thoại *</label>
                                    <div class="px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-800">
                                        @(string.IsNullOrEmpty(AuthService.CurrentUser.Phone) ? "Chưa cập nhật" : AuthService.CurrentUser.Phone)
                                    </div>
                                </div>
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Email *</label>
                                    <div class="px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-800">
                                        @AuthService.CurrentUser.Email
                                    </div>
                                </div>
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Địa chỉ giao hàng *</label>
                                    <div class="px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-gray-800 min-h-[80px]">
                                        @(string.IsNullOrEmpty(AuthService.CurrentUser.Address) ? "Chưa cập nhật địa chỉ" : AuthService.CurrentUser.Address)
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Manual input form -->
                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Họ và tên *</label>
                                    <input type="text" 
                                           class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all" 
                                           @bind="manualName" 
                                           placeholder="Nguyễn Văn A" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Số điện thoại *</label>
                                    <input type="tel" 
                                           class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all" 
                                           @bind="manualPhone" 
                                           placeholder="0912 345 678" />
                                </div>
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Email *</label>
                                    <input type="email" 
                                           class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all" 
                                           @bind="manualEmail" 
                                           placeholder="email@example.com" />
                                </div>
                                <div class="md:col-span-2">
                                    <label class="block text-sm font-medium text-gray-600 mb-1.5">Địa chỉ giao hàng *</label>
                                    <textarea class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all resize-none" 
                                              rows="3"
                                              @bind="manualAddress" 
                                              placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Phương thức thanh toán -->
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                        <div class="flex items-center gap-2 mb-5">
                            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                            <h2 class="text-lg font-bold text-gray-800">Phương thức thanh toán</h2>
                        </div>
                        
                        <div class="space-y-3">
                            <!-- COD -->
                            <button type="button" class="w-full text-left" @onclick="() => SelectPayment(PaymentMethod.cash)">
                                <div class="flex items-center gap-4 p-4 rounded-xl border-2 transition-all @(selectedPayment == PaymentMethod.cash ? "border-primary-500 bg-primary-50" : "border-gray-200 hover:border-gray-300")">
                                    <div class="w-5 h-5 rounded-full border-2 flex items-center justify-center @(selectedPayment == PaymentMethod.cash ? "border-primary-500" : "border-gray-300")">
                                        @if (selectedPayment == PaymentMethod.cash)
                                        {
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary-500"></div>
                                        }
                                    </div>
                                    <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center flex-shrink-0">
                                        <span class="text-2xl">🚚</span>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-gray-800">Thanh toán khi nhận hàng (COD)</div>
                                        <div class="text-sm text-gray-500">Thanh toán bằng tiền mặt khi nhận hàng</div>
                                    </div>
                                </div>
                            </button>
                            
                            <!-- Bank Transfer -->
                            <button type="button" class="w-full text-left" @onclick="() => SelectPayment(PaymentMethod.bank_transfer)">
                                <div class="flex items-center gap-4 p-4 rounded-xl border-2 transition-all @(selectedPayment == PaymentMethod.bank_transfer ? "border-primary-500 bg-primary-50" : "border-gray-200 hover:border-gray-300")">
                                    <div class="w-5 h-5 rounded-full border-2 flex items-center justify-center @(selectedPayment == PaymentMethod.bank_transfer ? "border-primary-500" : "border-gray-300")">
                                        @if (selectedPayment == PaymentMethod.bank_transfer)
                                        {
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary-500"></div>
                                        }
                                    </div>
                                    <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
                                        <span class="text-2xl">🏦</span>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-gray-800">Chuyển khoản ngân hàng</div>
                                        <div class="text-sm text-gray-500">Chuyển khoản trực tiếp qua tài khoản ngân hàng</div>
                                    </div>
                                </div>
                            </button>
                            
                            <!-- Card -->
                            <button type="button" class="w-full text-left" @onclick="() => SelectPayment(PaymentMethod.card)">
                                <div class="flex items-center gap-4 p-4 rounded-xl border-2 transition-all @(selectedPayment == PaymentMethod.card ? "border-primary-500 bg-primary-50" : "border-gray-200 hover:border-gray-300")">
                                    <div class="w-5 h-5 rounded-full border-2 flex items-center justify-center @(selectedPayment == PaymentMethod.card ? "border-primary-500" : "border-gray-300")">
                                        @if (selectedPayment == PaymentMethod.card)
                                        {
                                            <div class="w-2.5 h-2.5 rounded-full bg-primary-500"></div>
                                        }
                                    </div>
                                    <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
                                        <span class="text-2xl">💳</span>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-gray-800">Thanh toán bằng thẻ</div>
                                        <div class="text-sm text-gray-500">Visa, Mastercard, JCB</div>
                                    </div>
                                </div>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Order Summary -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
                        <div class="flex items-center gap-2 mb-5">
                            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                            <h2 class="text-lg font-bold text-gray-800">Đơn hàng của bạn</h2>
                        </div>
                        
                        <!-- Product List -->
                        <div class="space-y-3 mb-5 max-h-64 overflow-y-auto">
                            @foreach (var item in CartService.Items)
                            {
                                <div class="flex items-center gap-3">
                                    <div class="w-16 h-16 rounded-xl bg-gray-100 overflow-hidden flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center text-2xl">📦</div>
                                        }
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="font-medium text-gray-800 text-sm truncate">@item.Name</div>
                                        <div class="text-xs text-gray-500">SL: @item.Quantity</div>
                                        <div class="text-sm font-bold text-primary-600">@((item.Price * item.Quantity).ToString("N0"))đ</div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <!-- Summary -->
                        <div class="border-t border-gray-100 pt-4 space-y-3">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">Tạm tính:</span>
                                <span class="font-medium text-gray-800">@CartService.TotalPrice.ToString("N0")đ</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">Giảm giá:</span>
                                @if (selectedPromotion != null)
                                {
                                    var discountAmount = selectedPromotion.DiscountType == "percent" 
                                        ? (CartService.TotalPrice * selectedPromotion.DiscountValue / 100) 
                                        : selectedPromotion.DiscountValue;
                                    <span class="font-medium text-primary-600">-@discountAmount.ToString("N0")đ</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">-0đ</span>
                                }
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">Phí vận chuyển:</span>
                                <span class="font-medium text-primary-600">Miễn phí</span>
                            </div>
                            <div class="flex justify-between pt-3 border-t border-gray-100">
                                <span class="font-bold text-gray-800">Tổng cộng:</span>
                                <span class="text-xl font-extrabold text-primary-600">
                                    @if (selectedPromotion != null)
                                    {
                                        var discountAmount = selectedPromotion.DiscountType == "percent" 
                                            ? (CartService.TotalPrice * selectedPromotion.DiscountValue / 100) 
                                            : selectedPromotion.DiscountValue;
                                        var finalPrice = CartService.TotalPrice - discountAmount;
                                        @finalPrice.ToString("N0")<text>đ</text>
                                    }
                                    else
                                    {
                                        @CartService.TotalPrice.ToString("N0")<text>đ</text>
                                    }
                                </span>
                            </div>
                        </div>
                        
                        <!-- Promo Code -->
                        @if (_promotions != null && _promotions.Count > 0)
                        {
                            <div class="mt-5 pt-5 border-t border-gray-100">
                                @if (selectedPromotion != null)
                                {
                                    <div class="flex items-center justify-between px-4 py-3 rounded-xl bg-primary-50 border border-primary-200">
                                        <div class="flex items-center gap-2">
                                            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                            </svg>
                                            <span class="font-semibold text-primary-700">@selectedPromotion.PromoCode</span>
                                            <span class="text-sm text-primary-600">(-@selectedPromotion.DiscountValue@(selectedPromotion.DiscountType == "percent" ? "%" : "đ"))</span>
                                        </div>
                                        <button type="button" 
                                                class="text-gray-400 hover:text-red-500 transition-colors"
                                                @onclick="ClearPromotion">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                            </svg>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex gap-2">
                                        <select class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm bg-white" 
                                                @bind="selectedPromoId">
                                            <option value="">Mã giảm giá</option>
                                            @foreach (var promo in _promotions)
                                            {
                                                <option value="@promo.PromoId">@promo.PromoCode</option>
                                            }
                                        </select>
                                        <button type="button" 
                                                class="px-4 py-2.5 rounded-xl bg-primary-500 text-white font-semibold text-sm hover:bg-primary-600 transition-all"
                                                @onclick="ApplyPromotion">
                                            Áp dụng
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        
                        <!-- Submit Button -->
                        <button type="button" 
                                class="w-full mt-5 py-4 rounded-xl bg-primary-500 text-white font-bold text-base hover:bg-primary-600 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed shadow-lg shadow-primary-500/30"
                                @onclick="OnPlaceOrder"
                                disabled="@(_isLoading || CartService.Items.Count == 0)">
                            @if (_isLoading)
                            {
                                <div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                                <span>Đang xử lý...</span>
                            }
                            else
                            {
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                <span>Đặt hàng</span>
                            }
                        </button>
                        
                        <!-- Security Note -->
                        <div class="mt-4 flex items-center justify-center gap-2 text-xs text-gray-500">
                            <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                            <span>Thông tin của bạn được bảo mật an toàn</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@code {
    private bool _initialized = false;
    private bool _isLoading = false;
    private List<PromotionResponse>? _promotions;
    private PromotionResponse? selectedPromotion;
    private PaymentMethod selectedPayment { get; set; } = PaymentMethod.cash;
    
    // Customer info mode
    private bool useLoggedInUser = true;
    private string manualName = "";
    private string manualPhone = "";
    private string manualEmail = "";
    private string manualAddress = "";
    
    // Promotion selection
    private int? selectedPromoId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            try
            {
                await AuthService.InitializeAsync();

                if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
                {
                    Navigation.NavigateTo("/login");
                }
                else
                {
                    // Load promotions
                    await LoadPromotions();
                    StateHasChanged();
                }
            }
            catch
            {
                // ignore initialization errors
            }
        }
    }

    private async Task LoadPromotions()
    {
        try
        {
            _promotions = await PromotionService.GetPromotionsAsync((long)CartService.TotalPrice);
        }
        catch
        {
            _promotions = new List<PromotionResponse>();
            ToastService.ShowWarning("Không thể tải khuyến mãi", "Thông báo");
        }
    }

    private void SetCustomerMode(bool useLoggedIn)
    {
        useLoggedInUser = useLoggedIn;
        StateHasChanged();
    }

    private void SelectPayment(PaymentMethod method)
    {
        selectedPayment = method;
        StateHasChanged();
    }

    private void ApplyPromotion()
    {
        if (selectedPromoId.HasValue && _promotions != null)
        {
            selectedPromotion = _promotions.FirstOrDefault(p => p.PromoId == selectedPromoId.Value);
            if (selectedPromotion != null)
            {
                ToastService.ShowSuccess($"Đã áp dụng mã {selectedPromotion.PromoCode}", "✅ Thành công");
            }
        }
        StateHasChanged();
    }

    private void ClearPromotion()
    {
        selectedPromotion = null;
        selectedPromoId = null;
        StateHasChanged();
    }

    private void SelectPromotion(PromotionResponse? promotion)
    {
        selectedPromotion = promotion;
        StateHasChanged();
    }

    private async Task OnPlaceOrder()
    {
        if (CartService.Items.Count == 0)
        {
            ToastService.ShowError("Giỏ hàng trống!", "Lỗi");
            return;
        }

        // Validate manual input if not using logged in user
        if (!useLoggedInUser)
        {
            if (string.IsNullOrWhiteSpace(manualName) || string.IsNullOrWhiteSpace(manualEmail) || string.IsNullOrWhiteSpace(manualAddress))
            {
                ToastService.ShowError("Vui lòng điền đầy đủ thông tin khách hàng!", "Lỗi");
                return;
            }
        }

        _isLoading = true;

        try
        {
            // Calculate discount
            decimal discountAmountDecimal = 0;
            if (selectedPromotion != null)
            {
                discountAmountDecimal = selectedPromotion.DiscountType == "percent"
                    ? (CartService.TotalPrice * selectedPromotion.DiscountValue / 100)
                    : selectedPromotion.DiscountValue;
            }

            // Create proper DTO matching backend OrderRequest
            var orderRequest = new OrderRequest
            {
                CustomerId = AuthService.CurrentUser?.CustomerId,
                UserId = 1,
                promotionId = selectedPromotion?.PromoId,
                date = DateTime.UtcNow,
                PaymentMethod = (int)selectedPayment,
                totalAmount = (long)CartService.TotalPrice,
                discountAmount = (long)discountAmountDecimal,
                OrderStatus = 0, // pending
                listItems = CartService.Items.Select(item => new OrderItemRequest
                {
                    ProductId = item.ProductId,
                    Quantity = item.Quantity,
                    Price = item.Price
                }).ToList()
            };
            Console.WriteLine("--- OrderRequest Details ---");
            Console.WriteLine($"CustomerId: {orderRequest.CustomerId}");
            Console.WriteLine($"UserId: {orderRequest.UserId}");
            Console.WriteLine($"promotionId: {orderRequest.promotionId}");
            Console.WriteLine($"date: {orderRequest.date}");
            Console.WriteLine($"PaymentMethod: {orderRequest.PaymentMethod}");
            Console.WriteLine($"totalAmount: {orderRequest.totalAmount}");
            Console.WriteLine($"discountAmount: {orderRequest.discountAmount}");
            Console.WriteLine($"OrderStatus: {orderRequest.OrderStatus}");
            Console.WriteLine($"Total Items: {orderRequest.listItems.Count}");
            Console.WriteLine("--- List Items ---");
            foreach (var item in orderRequest.listItems)
            {
                Console.WriteLine($"  - ProductId: {item.ProductId}, Quantity: {item.Quantity}, Price: {item.Price}");
            }
            var orderResponse = await OrderService.CreateOrderAsync(orderRequest);

            if (orderResponse != null)
            {
                await CartService.ClearAsync();
                ToastService.ShowSuccess("Thanh toán thành công!", "✅ Thành công");
                await Task.Delay(300);
                Navigation.NavigateTo("/");
            }
            else
            {
                ToastService.ShowError("Thanh toán lỗi!", "❌ Lỗi");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Lỗi: {ex.Message}", "⚠️ Lỗi");
        }
        finally
        {
            _isLoading = false;
        }
    }

    public enum PaymentMethod
    {
        cash,
        bank_transfer,
        card
    }
}
