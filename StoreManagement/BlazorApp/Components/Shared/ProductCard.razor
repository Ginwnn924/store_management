@namespace BlazorApp.Components.Shared

<div class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl hover:border-primary-200 transition-all duration-300 animate-slide-up fresh-shadow"
    style="animation-delay: @AnimationDelayStyle;">
    <!-- Image Container -->
    <div class="relative overflow-hidden aspect-square bg-gray-50">
        <img src="@Product?.ImageUrl" alt="@Product?.ProductName"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />

        <!-- Discount badge: ProductResponse không có Discount -->

        <!-- New badge: ProductResponse không có IsNew -->

        @if ((Product?.StockQuantity ?? 0) <= 10 && (Product?.StockQuantity ?? 0) > 0)
        {
            <div
                class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full bg-warm-500 text-white text-xs font-bold shadow-lg">
                Còn @Product.StockQuantity @Product.Unit
            </div>
        }

        <!-- Quick Add Button -->
        <div
            class="absolute bottom-3 right-3 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <button
                class="p-3 rounded-full bg-primary-500 text-white hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/40">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Content -->
    <div class="p-4 space-y-2">
        <div class="flex items-center justify-between">
            <span
                class="text-xs text-primary-600 font-semibold uppercase tracking-wider bg-primary-50 px-2 py-0.5 rounded-full">@Product?.CategoryName</span>
            <span class="text-xs text-gray-400">/@Product?.Unit</span>
        </div>

        <h3 class="font-bold text-gray-800 group-hover:text-primary-600 transition-colors line-clamp-2 min-h-[2.5rem]">
            @Product?.ProductName
        </h3>

        <div class="flex items-center justify-between pt-2">
            <div>
                <span class="text-lg font-extrabold text-primary-600">@FormatPrice(Product?.Price ?? 0)</span>
                <!-- ProductResponse không có OriginalPrice -->
            </div>
        </div>

        <!-- Add to Cart Button -->
        <button
            class="w-full py-2.5 rounded-xl bg-gray-100 text-gray-700 font-semibold text-sm hover:bg-primary-500 hover:text-white transition-all duration-300 flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Thêm vào giỏ
        </button>
    </div>
</div>

@code {
    // ============== UI HELPERS ==============

    // Animation delay style for staggered animation
    private string AnimationDelayStyle => $"{AnimationDelay}s";

    // Format price for Vietnamese currency display
    private static string FormatPrice(decimal price) => $"{price:N0}đ";
}
