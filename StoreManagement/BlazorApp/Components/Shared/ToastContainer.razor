@namespace BlazorApp.Components.Shared
@using BlazorApp.Services
@rendermode InteractiveServer
@inject IToastService ToastService
@implements IDisposable

<div class="fixed top-24 right-4 z-[100] flex flex-col-reverse gap-3 pointer-events-none">
    @foreach (var toast in _toasts.OrderByDescending(t => t.Id))
    {
        <div @key="toast.Id"
            class="pointer-events-auto animate-slide-in-right group relative overflow-hidden rounded-2xl shadow-xl min-w-[360px] max-w-[420px] backdrop-blur-sm @GetToastClass(toast.Type)">

            <!-- Progress bar -->
            <div class="absolute bottom-0 left-0 h-1 @GetProgressClass(toast.Type) animate-progress-bar"></div>

            <!-- Main content -->
            <div class="p-4 flex items-start gap-4">
                <!-- Animated Icon -->
                <div
                    class="flex-shrink-0 w-11 h-11 rounded-xl @GetIconBgClass(toast.Type) flex items-center justify-center shadow-md animate-bounce-in">
                    @switch (toast.Type)
                    {
                        case ToastType.Success:
                            <svg class="w-5 h-5 @GetIconColorClass(toast.Type)" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                            </svg>
                            break;
                        case ToastType.Error:
                            <svg class="w-5 h-5 @GetIconColorClass(toast.Type)" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                            break;
                        case ToastType.Warning:
                            <svg class="w-5 h-5 @GetIconColorClass(toast.Type)" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            break;
                        case ToastType.Info:
                        default:
                            <svg class="w-5 h-5 @GetIconColorClass(toast.Type)" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            break;
                    }
                </div>

                <!-- Text Content -->
                <div class="flex-1 min-w-0 pt-0.5">
                    @if (!string.IsNullOrEmpty(toast.Title))
                    {
                        <h4 class="font-bold @GetTitleColorClass(toast.Type) text-sm leading-tight">@toast.Title</h4>
                    }
                    <p class="text-gray-600 text-sm mt-0.5 leading-relaxed">@toast.Message</p>
                </div>

                <!-- Close Button -->
                <button @onclick="() => RemoveToast(toast.Id)"
                    class="flex-shrink-0 w-7 h-7 rounded-lg hover:bg-gray-100 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-all opacity-0 group-hover:opacity-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<ToastItem> _toasts = new();
    private int _toastId = 0;

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private void ShowToast(ToastMessage message)
    {
        var toast = new ToastItem
        {
            Id = ++_toastId,
            Message = message.Message,
            Title = message.Title,
            Type = message.Type
        };

        _toasts.Add(toast);
        InvokeAsync(StateHasChanged);

        // Auto remove after 3.5 seconds
        _ = Task.Delay(3500).ContinueWith(_ =>
        {
            RemoveToast(toast.Id);
        });
    }

    private void RemoveToast(int id)
    {
        var toast = _toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null)
        {
            _toasts.Remove(toast);
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }

    private string GetToastClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-emerald-50 border border-emerald-200",
        ToastType.Error => "bg-red-50 border border-red-200",
        ToastType.Warning => "bg-amber-50 border border-amber-200",
        ToastType.Info => "bg-blue-50 border border-blue-200",
        _ => "bg-gray-50 border border-gray-200"
    };

    private string GetIconBgClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-emerald-100",
        ToastType.Error => "bg-red-100",
        ToastType.Warning => "bg-amber-100",
        ToastType.Info => "bg-blue-100",
        _ => "bg-gray-100"
    };

    private string GetIconColorClass(ToastType type) => type switch
    {
        ToastType.Success => "text-emerald-600",
        ToastType.Error => "text-red-600",
        ToastType.Warning => "text-amber-600",
        ToastType.Info => "text-blue-600",
        _ => "text-gray-600"
    };

    private string GetTitleColorClass(ToastType type) => type switch
    {
        ToastType.Success => "text-emerald-800",
        ToastType.Error => "text-red-800",
        ToastType.Warning => "text-amber-800",
        ToastType.Info => "text-blue-800",
        _ => "text-gray-800"
    };

    private string GetProgressClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-emerald-400",
        ToastType.Error => "bg-red-400",
        ToastType.Warning => "bg-amber-400",
        ToastType.Info => "bg-blue-400",
        _ => "bg-gray-400"
    };

    private class ToastItem
    {
        public int Id { get; set; }
        public string Message { get; set; } = "";
        public string? Title { get; set; }
        public ToastType Type { get; set; }
    }
}
