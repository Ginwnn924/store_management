@namespace BlazorApp.Components.Shared
@rendermode InteractiveServer

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <NavLink href="/" Match="NavLinkMatch.All" class="flex items-center space-x-2">
                <div
                    class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center shadow-lg shadow-primary-500/30">
                    <span class="text-white text-xl">🛒</span>
                </div>
                <div>
                    <span class="text-xl font-extrabold text-primary-600">Green</span><span
                        class="text-xl font-extrabold text-warm-500">Store</span>
                    <div class="text-[10px] text-gray-400 -mt-1">Tươi ngon mỗi ngày</div>
                </div>
            </NavLink>

            <!-- Navigation -->
            <nav class="hidden md:flex items-center space-x-8">
                <a href="#"
                    class="text-gray-600 hover:text-primary-600 transition-colors duration-200 text-sm font-semibold flex items-center gap-1">
                    <span>🏠</span> Trang chủ
                </a>
                <a href="#"
                    class="text-gray-600 hover:text-primary-600 transition-colors duration-200 text-sm font-semibold flex items-center gap-1">
                    <span>🥬</span> Sản phẩm
                </a>
                <a href="#"
                    class="text-gray-600 hover:text-primary-600 transition-colors duration-200 text-sm font-semibold flex items-center gap-1">
                    <span>🏷️</span> Khuyến mãi
                </a>
                <a href="#"
                    class="text-gray-600 hover:text-primary-600 transition-colors duration-200 text-sm font-semibold flex items-center gap-1">
                    <span>📞</span> Liên hệ
                </a>
            </nav>

            <!-- Search & Actions -->
            <div class="flex items-center space-x-3">
                <!-- Search -->
                <div
                    class="hidden lg:flex items-center bg-gray-100 rounded-full px-4 py-2 focus-within:ring-2 focus-within:ring-primary-500 transition-all">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" placeholder="Tìm sản phẩm..."
                        class="bg-transparent border-none outline-none text-sm text-gray-700 placeholder-gray-400 ml-2 w-44" />
                </div>

                <!-- Hotline -->
                <div
                    class="hidden xl:flex items-center space-x-2 px-3 py-1.5 rounded-full bg-primary-50 border border-primary-200">
                    <span class="text-lg animate-wiggle">📞</span>
                    <div class="text-xs">
                        <div class="text-gray-500">Hotline</div>
                        <div class="font-bold text-primary-600">1900 1234</div>
                    </div>
                </div>

                <!-- Cart -->
                <button @onclick="OpenCart"
                    class="relative p-2.5 bg-primary-50 rounded-full text-primary-600 hover:bg-primary-100 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    @if (CartItemCount > 0)
                    {
                        <span
                            class="absolute -top-1 -right-1 w-5 h-5 bg-warm-500 rounded-full text-xs flex items-center justify-center font-bold text-white animate-pulse">@CartItemCount</span>
                    }
                </button>

                <!-- User -->
                @if (AuthService.IsAuthenticated && AuthService.CurrentUser != null)
                {
                    <a href="/profile"
                        class="flex items-center gap-2 px-3 py-2 bg-gradient-to-r from-primary-50 to-fresh-50 rounded-full hover:from-primary-100 hover:to-fresh-100 transition-all border border-primary-200">
                        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <span class="hidden sm:block text-sm font-semibold text-primary-700">
                            Xin chào, <br>
                            @GetLastName(AuthService.CurrentUser.Name)
                        </span>
                    </a>
                }
                else
                {
                    <a href="/login"
                        class="p-2.5 bg-gray-100 rounded-full text-gray-600 hover:bg-gray-200 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </a>
                }

                <!-- Mobile Menu -->
                <button class="md:hidden p-2 text-gray-600 hover:text-primary-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Promo Banner -->
    <div class="bg-gradient-to-r from-primary-500 to-fresh-500 text-white text-center py-1.5 text-sm font-medium">
        🎉 <span class="font-bold">FREESHIP</span> cho đơn hàng từ 200K | Giảm thêm <span class="font-bold">10%</span>
        cho thành viên mới! 🎉
    </div>
</header>

<!-- Cart Drawer -->
<CartDrawer @bind-IsOpen="IsCartOpen" />
