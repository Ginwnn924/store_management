@using BlazorApp.Models
@inject NavigationManager NavigationManager

@if (Show && Order != null)
{
    <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
        <div class="bg-white rounded-xl shadow-lg p-8 w-full max-w-lg relative">
            <button class="absolute top-2 right-2 text-gray-400 hover:text-red-500" @onclick="Close">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            <div class="text-green-500 text-5xl mb-2 text-center">✔️</div>
            <h2 class="text-xl font-bold text-center mb-2">Thanh toán thành công!</h2>
            <p class="text-center text-gray-600 mb-4">Cảm ơn bạn đã mua hàng. Thông tin đơn hàng:</p>
            <div class="mb-4">
                <div><b>Mã đơn hàng:</b> @Order.Id</div>
                <div><b>Ngày đặt:</b> @Order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                <div><b>Tổng tiền:</b> @Order.TotalAmount.ToString("N0") đ</div>
                <div><b>Giảm giá:</b> @Order.DiscountAmount.ToString("N0") đ</div>
            </div>
            <div>
                <b>Danh sách sản phẩm:</b>
                <table class="min-w-full border mt-2">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="px-3 py-2 text-left">Tên sản phẩm</th>
                            <th class="px-3 py-2 text-center">Số lượng</th>
                            <th class="px-3 py-2 text-right">Giá</th>
                            <th class="px-3 py-2 text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Order.ListItem)
                        {
                            <tr>
                                <td class="px-3 py-2">@item.ProductName</td>
                                <td class="px-3 py-2 text-center">@item.Quantity</td>
                                <td class="px-3 py-2 text-right">@item.Price.ToString("N0") đ</td>
                                <td class="px-3 py-2 text-right">@item.SubTotal.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-6 flex justify-center">
                <button class="px-6 py-2 rounded-xl bg-primary-500 text-white font-semibold hover:bg-primary-600 transition-colors"
                        @onclick="ContinueShopping">
                    Tiếp tục mua sắm
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public OrderResponse? Order { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private void Close() => OnClose.InvokeAsync();

    private void ContinueShopping()
    {
        OnClose.InvokeAsync();
        NavigationManager.NavigateTo("/");
    }
}