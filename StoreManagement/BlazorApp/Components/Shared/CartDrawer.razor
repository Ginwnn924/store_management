@namespace BlazorApp.Components.Shared
@using BlazorApp.Services
@using BlazorApp.Models
@inject ICartService CartService
@inject IOrderService OrderService
@inject NavigationManager NavigationManager
@implements IDisposable
@inject ILogger<CartDrawer> Logger

@using BlazorApp.Models.Auth
@inject IAuthService AuthService

@if (IsOpen)
{
    <!-- Overlay Background -->
    <div class="fixed inset-0 bg-black/50 z-50 animate-fade-in" @onclick="Close"></div>
}

<!-- Cart Drawer -->
<aside style="transform: translateX(@(IsOpen ? "0" : "100%")); will-change: transform;"
    class="fixed top-0 right-0 h-full w-full sm:w-96 bg-white shadow-2xl z-50 flex flex-col transition-transform duration-300 ease-out">
    <!-- Header -->
    <div class="flex items-center justify-between p-4 border-b border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center">
                <span class="text-xl">🛒</span>
            </div>
            <div>
                <h2 class="text-lg font-bold text-gray-800">Giỏ hàng</h2>
                <p class="text-sm text-gray-500">@CartService.TotalCount sản phẩm</p>
            </div>
        </div>
        <button @onclick="Close"
            class="p-2 rounded-xl hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <!-- Cart Content -->
    <div class="flex-1 overflow-y-auto p-4 space-y-4">
        @if (CartService.Items.Count == 0)
        {
            <!-- Empty State -->
            <div class="flex flex-col items-center justify-center h-full text-center py-12">
                <div class="w-24 h-24 rounded-full bg-gray-100 flex items-center justify-center mb-4">
                    <span class="text-4xl">🛒</span>
                </div>
                <h3 class="text-lg font-bold text-gray-800 mb-2">Giỏ hàng trống</h3>
                <p class="text-gray-500 text-sm mb-6">Hãy thêm sản phẩm vào giỏ hàng</p>
                <button @onclick="Close"
                    class="px-6 py-2.5 rounded-xl bg-primary-500 text-white font-semibold hover:bg-primary-600 transition-colors">
                    Tiếp tục mua sắm
                </button>
            </div>
        }
        else
        {
            @foreach (var item in CartService.Items)
            {
                <!-- Cart Item -->
                <div @key="item.ProductId"
                    class="flex gap-3 p-3 bg-gray-50 rounded-2xl group hover:bg-gray-100 transition-colors">
                    <!-- Product Image -->
                    <div class="w-20 h-20 rounded-xl overflow-hidden bg-white flex-shrink-0">
                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                    </div>

                    <!-- Product Info -->
                    <div class="flex-1 min-w-0">
                        <h4 class="font-semibold text-gray-800 text-sm truncate">@item.Name</h4>
                        <p class="text-xs text-gray-500 mb-1">@item.CategoryName</p>

                        <div class="flex items-center justify-between">
                            <!-- Quantity Controls -->
                            <div class="flex items-center gap-1 bg-white rounded-lg border border-gray-200">
                                <button @onclick="() => DecreaseQuantityAsync(item)"
                                    class="w-7 h-7 flex items-center justify-center text-gray-500 hover:text-primary-600 transition-colors">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                    </svg>
                                </button>
                                <span class="w-8 text-center text-sm font-semibold">@item.Quantity</span>
                                <button @onclick="() => IncreaseQuantityAsync(item)"
                                    class="w-7 h-7 flex items-center justify-center text-gray-500 hover:text-primary-600 transition-colors">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 4v16m8-8H4" />
                                    </svg>
                                </button>
                            </div>

                            <!-- Price -->
                            <span class="font-bold text-primary-600 text-sm">@FormatPrice(item.Price * item.Quantity)
                            </span>
                        </div>
                    </div>

                    <!-- Remove Button -->
                    <button @onclick="() => RemoveItemAsync(item)"
                        class="self-start p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 opacity-0 group-hover:opacity-100 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            }
        }
    </div>

    <!-- Footer -->
    @if (CartService.Items.Count > 0)
    {
        <div class="border-t border-gray-100 p-4 space-y-4 bg-white">
            <!-- Discount Code -->
            <div class="flex gap-2">
                <input type="text" placeholder="Mã giảm giá"
                    class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-sm focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20" />
                <button
                    class="px-4 py-2.5 rounded-xl border-2 border-primary-500 text-primary-600 font-semibold text-sm hover:bg-primary-50 transition-colors">
                    Áp dụng
                </button>
            </div>

            <!-- Summary -->
            <div class="space-y-2 text-sm">
                <div class="flex justify-between text-gray-600">
                    <span>Tạm tính</span>
                    <span>@FormatPrice(CartService.TotalPrice)</span>
                </div>
                <div class="flex justify-between text-gray-600">
                    <span>Phí vận chuyển</span>
                    <span class="text-green-600 font-medium">Miễn phí</span>
                </div>
                <div class="h-px bg-gray-200 my-2"></div>
                <div class="flex justify-between text-lg font-bold">
                    <span>Tổng cộng</span>
                    <span class="text-primary-600">@FormatPrice(CartService.TotalPrice)</span>
                </div>
            </div>

            <!-- Checkout Button -->
            <button
                class="w-full py-4 rounded-2xl bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold hover:from-primary-600 hover:to-primary-700 transition-all shadow-lg shadow-primary-500/30 flex items-center justify-center gap-2"
                @onclick="OnCheckoutAsync"
                disabled="@isProcessing">
                <span>Thanh toán</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
            </button>

            <!-- Continue Shopping -->
            <button @onclick="Close"
                class="w-full py-3 rounded-xl text-gray-600 font-semibold hover:bg-gray-100 transition-colors text-sm">
                ← Tiếp tục mua sắm
            </button>
        </div>
    }
</aside>

<OrderSuccessModal Show="@showSuccessModal" Order="@orderSuccess" OnClose="HideSuccessModal" />

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private bool showSuccessModal = false;
    private OrderResponse? orderSuccess;

    protected override async Task OnInitializedAsync()
    {
        CartService.OnChange += HandleCartChanged;
        await CartService.InitializeAsync();
    }

    private void HandleCartChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleCartChanged;
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task IncreaseQuantityAsync(CartItem item)
    {
        await CartService.UpdateQuantityAsync(item.ProductId, item.Quantity + 1);
    }

    private async Task DecreaseQuantityAsync(CartItem item)
    {
        await CartService.UpdateQuantityAsync(item.ProductId, item.Quantity - 1);
    }

    private async Task RemoveItemAsync(CartItem item)
    {
        await CartService.RemoveItemAsync(item.ProductId);
    }

    private static string FormatPrice(decimal price) => $"{price:N0}đ";

    private bool isProcessing = false;

    private async Task OnCheckoutAsync()
    {
        if (CartService.Items.Count == 0 || isProcessing)
            return;

        isProcessing = true;

        // Kiểm tra đăng nhập
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login", true);
            isProcessing = false;
            return;
        }
        Logger.LogInformation("User is authenticated, proceeding to checkout.");
        // Nếu đã đăng nhập, chuyển sang trang checkout
        NavigationManager.NavigateTo("/checkout");
        isProcessing = false;
        Close();
    }

    private void HideSuccessModal()
    {
        showSuccessModal = false;
    }
}
